{
  "name": "fridge-to-recipe",
  "private": true,
  "version": "1.0.0",
  "workspaces": [
    "backend",
    "frontend"
  ],
  "scripts": {
    "start": "concurrently -n backend,frontend -c yellow,cyan \"npm run dev -w backend\" \"npm run dev -w frontend\"",
    "dev": "npm run start",
    "backend": "npm run dev -w backend",
    "frontend": "npm run dev -w frontend"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
